default_mode "locked"

layout {
    tab {
        pane split_direction="vertical" {
            pane split_direction="horizontal" size="50%" {
                pane command="claude" size="80%" focus=true
                pane size="20%"
            }
            pane command="branchdiff" size="50%"
        }
    }
}

on_force_close "quit"
session_serialization false
